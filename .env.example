# Mastodon credentials — get these by creating an app at https://your.instance/settings/applications
MASTODON_ACCESS_TOKEN=your_access_token_here
MASTODON_CLIENT_ID=your_client_id_here
MASTODON_CLIENT_SECRET=your_client_secret_here
MASTODON_API_BASE_URL=https://your.mastodon.instance

# Bot's own account ID — find it at https://your.instance/api/v1/accounts/verify_credentials
BOT_ACCOUNT_ID=123456789

# Giphy — get a free API key at https://developers.giphy.com
GIPHY_API_KEY=your_giphy_api_key_here

# Bot behaviour
GIPHY_RESULT_COUNT=3
GIPHY_RATING=g
SESSION_TTL_SECONDS=600
RATE_LIMIT_PER_USER_SECONDS=30
BOT_VISIBILITY=unlisted

# Local GIFs
LOCAL_GIFS_DIR=./local_gifs
LOCAL_GIF_BASE_URL=
FUZZY_MATCH_THRESHOLD=65
