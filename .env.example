# ─── Mastodon credentials ───────────────────────────────────────────────────
# Create an app at https://your.instance/settings/applications
# Required scopes: read, write, follow
MASTODON_ACCESS_TOKEN=your_access_token_here
MASTODON_CLIENT_ID=your_client_id_here
MASTODON_CLIENT_SECRET=your_client_secret_here
MASTODON_API_BASE_URL=https://your.mastodon.instance

# Bot's own account ID — find it at https://your.instance/api/v1/accounts/verify_credentials
BOT_ACCOUNT_ID=123456789

# ─── Giphy API ──────────────────────────────────────────────────────────────
# Free tier at https://developers.giphy.com
GIPHY_API_KEY=your_giphy_api_key_here
GIPHY_RESULT_COUNT=3
GIPHY_RATING=g

# ─── Bot behaviour ──────────────────────────────────────────────────────────
SESSION_TTL_SECONDS=600
RATE_LIMIT_PER_USER_SECONDS=30
BOT_VISIBILITY=unlisted
# Auto-follow back anyone who follows the bot (true/false)
AUTO_FOLLOW_BACK=true

# ─── Local GIFs ─────────────────────────────────────────────────────────────
LOCAL_GIFS_DIR=./local_gifs
LOCAL_GIF_BASE_URL=
FUZZY_MATCH_THRESHOLD=65

# ─── Logging & polling ──────────────────────────────────────────────────────
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
POLL_INTERVAL_SECONDS=10

# ─── Safety circuit breaker ─────────────────────────────────────────────────
# If the bot tries to post more than MAX_MESSAGES_PER_MINUTE messages in any
# rolling 60-second window, it stops posting for COOLDOWN_SECONDS and notifies
# the admin via DM. Set ADMIN_ACCT to your handle to receive these alerts
# (without the leading @ — e.g. "alice" or "alice@social.example.com").
MAX_MESSAGES_PER_MINUTE=6
COOLDOWN_SECONDS=300
ADMIN_ACCT=
